# Shared environment variables for MTGPros DJ
# Copy this file to `.env` and adjust values for your environment.

# Spotify API Credentials
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/auth/callback

# Server Configuration
PORT=5000
NODE_ENV=development
SESSION_SECRET=your_random_session_secret_here_change_this
# Primary frontend URL (used for redirects)
FRONTEND_URL=http://localhost:5173
# Comma-separated list of allowed frontend origins for CORS/socket access
# Example: FRONTEND_ORIGINS=http://localhost:5173,https://dj-dev.pros.mortgage
FRONTEND_ORIGINS=http://localhost:5173
# Frontend runtime configuration exposed via /api/config
FRONTEND_API_BASE_URL=http://localhost:5000/api
FRONTEND_SOCKET_URL=http://localhost:5000
FRONTEND_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Database
DATABASE_URL="file:./dev.db"

# Logto Authentication (required)
LOGTO_ENDPOINT=https://your-logto-instance
LOGTO_APP_ID=your_logto_app_id
LOGTO_API_RESOURCE=https://your-api-resource

# Logto Management API (optional) — lets the backend resolve a user's
# display name from their Logto ID instead of trusting the client. Create a
# Machine-to-Machine app in Logto with the "Logto Management API" permission.
# LOGTO_M2M_APP_ID=your_m2m_app_id
# LOGTO_M2M_APP_SECRET=your_m2m_app_secret
# Management API resource indicator. Self-hosted default shown; on Logto
# Cloud use https://<tenant-id>.logto.app/api
# LOGTO_MANAGEMENT_RESOURCE=https://default.logto.app/api

# Librespot (optional headless Spotify Connect receiver)
LIBRESPOT_ENABLED=false
LIBRESPOT_DEVICE_NAME=MortgagePros DJ
LIBRESPOT_TRANSFER_ON_QUEUE=true
LIBRESPOT_DISCOVERY_TIMEOUT_MS=15000
# Provide credentials when not using Zeroconf discovery (optional)
# LIBRESPOT_USERNAME=
# LIBRESPOT_PASSWORD=
# LIBRESPOT_BITRATE=160
# LIBRESPOT_BACKEND=rodio
# LIBRESPOT_DISABLE_DISCOVERY=
# LIBRESPOT_EXTRA_ARGS=

# Legacy Vite environment variables (optional for local tooling)
# VITE_API_URL=http://localhost:5000/api
# VITE_SOCKET_URL=http://localhost:5000
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
